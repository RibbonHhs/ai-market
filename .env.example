# Backend 环境变量模板（拷贝为 .env 后注入）
# 后端读取顺序：环境变量 > application-{profile}.yml 默认值

# 运行环境
SPRING_PROFILES_ACTIVE=dev
SERVER-PORT=8767

# 数据库（仅 local / prod 用，dev 走 H2 内存库）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=skillsmap
DB_USER=skillsmap
DB_PASSWORD=skillsmap

# Jasypt 加密（生产环境务必修改）
JASYPT_PASSWORD=skillsmap-jasypt-key

# JWT 密钥（生产环境务必修改，长度 ≥ 32 字节）
JWT_SECRET=skillsmap-jwt-secret-key-please-change-in-production-environment-2024

# 种子数据
SKILLSMAP_SEED_ENABLED=true
SKILLSMAP_LOCAL_SKILLS_PATH=C:/Users/86133/.claude/skills
SKILLSMAP_LOCAL_PLUGINS_PATH=C:/Users/86133/.claude/plugins/marketplaces/claude-plugins-official/plugins

# API 文档
SPRING-API-DOCS-ENABLED=true
